generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String         @unique
  username      String         @unique
  password      String
  creditBalance Float          @default(500)
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  trips         Trip[]         @relation("DriverTrips")
  joinRequests  JoinRequest[]  @relation("RiderRequests")
  sentTx        Transaction[]  @relation("SentTransactions")
  receivedTx    Transaction[]  @relation("ReceivedTransactions")
  announcements Announcement[] @relation("SentAnnouncements")
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Trip {
  id             String        @id @default(uuid())
  driverId       String
  driver         User          @relation("DriverTrips", fields: [driverId], references: [id])
  originName     String
  originLat      Float
  originLng      Float
  destName       String
  destLat        Float
  destLng        Float
  departureTime  DateTime
  availableSeats Int
  totalSeats     Int
  creditsPerSeat Float
  status         TripStatus    @default(SCHEDULED)
  createdAt      DateTime      @default(now())
  joinRequests   JoinRequest[]
  transactions   Transaction[]
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model JoinRequest {
  id        String        @id @default(uuid())
  tripId    String
  trip      Trip          @relation(fields: [tripId], references: [id])
  riderId   String
  rider     User          @relation("RiderRequests", fields: [riderId], references: [id])
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@unique([tripId, riderId])
}

enum TransactionType {
  TRIP_PAYMENT
  REFUND
}

model Announcement {
  id        String   @id @default(uuid())
  subject   String
  body      String
  sentBy    String
  sender    User     @relation("SentAnnouncements", fields: [sentBy], references: [id])
  audience  String   @default("all") // "all" or comma-separated user IDs
  userCount Int
  createdAt DateTime @default(now())
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  phone     String
  username  String
  password  String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email])
}

model Transaction {
  id         String          @id @default(uuid())
  tripId     String
  trip       Trip            @relation(fields: [tripId], references: [id])
  fromUserId String
  fromUser   User            @relation("SentTransactions", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User            @relation("ReceivedTransactions", fields: [toUserId], references: [id])
  amount     Float
  type       TransactionType
  createdAt  DateTime        @default(now())
}
