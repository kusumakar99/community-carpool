generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String         @unique
  username      String         @unique
  password      String
  gender        String?
  age           Int?
  creditBalance Float          @default(500)
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  trips         Trip[]         @relation("DriverTrips")
  joinRequests  JoinRequest[]  @relation("RiderRequests")
  sentTx        Transaction[]  @relation("SentTransactions")
  receivedTx    Transaction[]  @relation("ReceivedTransactions")
  announcements Announcement[] @relation("SentAnnouncements")
  communities        CommunityMember[] @relation("CommunityMemberships")
  createdCommunities Community[]       @relation("CreatedCommunities")
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Trip {
  id             String        @id @default(uuid())
  driverId       String
  driver         User          @relation("DriverTrips", fields: [driverId], references: [id])
  originName     String
  originLat      Float
  originLng      Float
  destName       String
  destLat        Float
  destLng        Float
  departureTime  DateTime
  availableSeats Int
  totalSeats     Int
  creditsPerSeat Float
  status         TripStatus    @default(SCHEDULED)
  createdAt      DateTime      @default(now())
  joinRequests   JoinRequest[]
  transactions   Transaction[]
  communityId    String?
  community      Community?    @relation("CommunityTrips", fields: [communityId], references: [id])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model JoinRequest {
  id        String        @id @default(uuid())
  tripId    String
  trip      Trip          @relation(fields: [tripId], references: [id])
  riderId   String
  rider     User          @relation("RiderRequests", fields: [riderId], references: [id])
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@unique([tripId, riderId])
}

enum TransactionType {
  TRIP_PAYMENT
  REFUND
}

model Announcement {
  id        String   @id @default(uuid())
  subject   String
  body      String
  sentBy    String
  sender    User     @relation("SentAnnouncements", fields: [sentBy], references: [id])
  audience  String   @default("all") // "all" or comma-separated user IDs
  userCount Int
  createdAt DateTime @default(now())
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  phone     String
  username  String
  password  String
  gender    String?
  age       Int?
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email])
}

model Transaction {
  id         String          @id @default(uuid())
  tripId     String
  trip       Trip            @relation(fields: [tripId], references: [id])
  fromUserId String
  fromUser   User            @relation("SentTransactions", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User            @relation("ReceivedTransactions", fields: [toUserId], references: [id])
  amount     Float
  type       TransactionType
  createdAt  DateTime        @default(now())
}

model Community {
  id             String            @id @default(uuid())
  name           String
  description    String?
  inviteCode     String            @unique
  createdBy      String
  creator        User              @relation("CreatedCommunities", fields: [createdBy], references: [id])
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  members        CommunityMember[]
  trips          Trip[]            @relation("CommunityTrips")
  approvedPhones ApprovedPhone[]
}

model CommunityMember {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  userId      String
  user        User      @relation("CommunityMemberships", fields: [userId], references: [id])
  role        String    @default("member")
  status      String    @default("active")
  joinedAt    DateTime  @default(now())

  @@unique([communityId, userId])
}

model ApprovedPhone {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  phone       String
  addedBy     String
  addedAt     DateTime  @default(now())

  @@unique([communityId, phone])
}
